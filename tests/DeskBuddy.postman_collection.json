{
  "info": {
    "name": "DeskBuddy API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5294" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
            ]}
          }]
        }
      ]
    },
    {
      "name": "Devices",
      "item": [
        {
          "name": "POST /api/devices – Create device",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/devices",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Desk-Device-01\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has id', () => pm.expect(pm.response.json().id).to.be.a('number'));",
              "pm.collectionVariables.set('deviceId', pm.response.json().id);"
            ]}
          }]
        },
        {
          "name": "GET /api/devices – Get all",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/devices"
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]}
          }]
        },
        {
          "name": "GET /api/devices/{id} – Get by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/devices/{{deviceId}}"
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Correct id', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('deviceId')));"
            ]}
          }]
        },
        {
          "name": "PUT /api/devices/{id} – Update device",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/devices/{{deviceId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Desk-Device-01-Updated\",\n  \"isOnline\": true,\n  \"batteryLevel\": 80,\n  \"mood\": \"happy\",\n  \"mode\": \"focus\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ]}
          }]
        },
        {
          "name": "DELETE /api/devices/{id} – Delete device",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/devices/{{deviceId}}"
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ]}
          }]
        },
        {
          "name": "GET /api/devices/{id} – 404 after delete",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/devices/{{deviceId}}"
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));"
            ]}
          }]
        },
        {
          "name": "POST /api/devices – Validation: empty name",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/devices",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Has errors', () => pm.expect(pm.response.json().errors).to.exist);"
            ]}
          }]
        },
        {
          "name": "PUT /api/devices – Validation: battery out of range",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/devices/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test\",\n  \"isOnline\": true,\n  \"batteryLevel\": 150,\n  \"mood\": \"neutral\",\n  \"mode\": \"normal\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));"
            ]}
          }]
        }
      ]
    },
    {
      "name": "CalendarEvents",
      "item": [
        {
          "name": "POST /api/calendarevents – Create event",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/calendarevents",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Team Meeting\",\n  \"startTime\": \"2026-04-22T09:00:00\",\n  \"endTime\": \"2026-04-22T10:00:00\",\n  \"location\": \"Room 1\",\n  \"description\": \"Weekly sync\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has id', () => pm.expect(pm.response.json().id).to.be.a('number'));",
              "pm.collectionVariables.set('eventId', pm.response.json().id);"
            ]}
          }]
        },
        {
          "name": "GET /api/calendarevents – Get all",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/calendarevents"
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]}
          }]
        },
        {
          "name": "GET /api/calendarevents/{id} – Get by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/calendarevents/{{eventId}}"
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Correct title', () => pm.expect(pm.response.json().title).to.eql('Team Meeting'));"
            ]}
          }]
        },
        {
          "name": "PUT /api/calendarevents/{id} – Update event",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/calendarevents/{{eventId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Team Meeting Updated\",\n  \"startTime\": \"2026-04-22T09:00:00\",\n  \"endTime\": \"2026-04-22T11:00:00\",\n  \"location\": \"Room 2\",\n  \"description\": \"Updated sync\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ]}
          }]
        },
        {
          "name": "DELETE /api/calendarevents/{id} – Delete event",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/calendarevents/{{eventId}}"
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ]}
          }]
        },
        {
          "name": "POST /api/calendarevents – Validation: missing title",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/calendarevents",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"startTime\": \"2026-04-22T09:00:00\",\n  \"endTime\": \"2026-04-22T10:00:00\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Has errors', () => pm.expect(pm.response.json().errors).to.exist);"
            ]}
          }]
        }
      ]
    }
  ]
}
